# ──────────────────────────────────────────────────────────
#  Ash AI Healthcare Assistant — Environment Configuration
# ──────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  The app works fully in offline mode without GEMINI_API_KEY.

# Server port (default: 3000)
PORT=3000

# Gemini API key — get one free at https://aistudio.google.com/app/apikey
# Leave blank to run in offline-only mode using the local medical knowledge base.
GEMINI_API_KEY=

# Ash AI identity (optional — defaults shown)
AI_NAME=Ash
ORG_NAME=Ash AI Healthcare
